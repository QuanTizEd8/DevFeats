{
  "name": "DevFeats Development Environment",
  "containerUser": "devfeats-dev",
  "remoteUser": "devfeats-dev",
  "build": {
    // Currently, there is no way to define cache sources when using "image",
    // so we have to use "dockerfile" even though we don't need a custom one.
    "dockerfile": "Dockerfile",
    "options": [
      "--progress=plain"
    ],
    "cacheFrom": [
      "ghcr.io/quantized8/sysset-devcontainer:cache-linux-amd64",
      "ghcr.io/quantized8/sysset-devcontainer:cache-linux-arm64"
    ]
  },
  "features": {
    "ghcr.io/quantized8/sysset/setup-user": {
      "username": "devfeats-dev"
    },
    "ghcr.io/quantized8/sysset/install-gh": {},

    "ghcr.io/quantized8/sysset/install-git": {"version": "stable"},

    "ghcr.io/quantized8/sysset/install-jq": {},
    "ghcr.io/quantized8/sysset/install-just": {
      "version": "1.50.0"
    },
    "ghcr.io/quantized8/sysset/install-shfmt": {
      "version": "3.13.1"
    },
    "ghcr.io/quantized8/sysset/install-shellcheck": {
      "version": "0.11.0"
    },

    // "ghcr.io/quantized8/sysset/install-miniforge": {},

    "ghcr.io/quantized8/sysset/install-pixi": {},
    "ghcr.io/quantized8/sysset/install-shell": {},
    "ghcr.io/quantized8/sysset/install-yq": {},
    "ghcr.io/quantized8/sysset/install-devcontainer-cli": {},
    "ghcr.io/quantized8/sysset/install-oras": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
  },
  // Stop the container when VS Code window closes (prevents orphaned containers on clean disconnect)
  "shutdownAction": "stopContainer",

  // Share host ~/.claude into container so all invocations of this workspace share the same chat history.
  // The postStartCommand below symlinks the container's project key to the host's, so Claude Code
  // finds the same conversations regardless of whether it's running inside or outside the container.
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/devfeats-dev/.claude,type=bind,consistency=cached",
    "source=devfeats-vscode-server,target=/home/devfeats-dev/.vscode-server,type=volume",
    // Both storage paths are always mounted; the script uses whichever has workspace.json files.
    // Object format required for the macOS path — "Application Support" contains a space.
    {
      "source": "${localEnv:HOME}/Library/Application Support/Code/User/workspaceStorage",
      "target": "/host-vscode-workspacestorage",
      "type": "bind"
    },
    "source=${localEnv:HOME}/.config/Code/User/workspaceStorage,target=/host-vscode-workspacestorage-linux,type=bind"
  ],

  // Limit CPU to avoid host starvation if a process spirals (uncomment and tune as needed)
  // "runArgs": ["--cpus=3"],

  // "postCreateCommand": "lefthook install",
  "postStartCommand": {
    "initialize_bats_submodules": "git submodule update --init --recursive",
    "pixi_install": "pixi install --all",
    // Symlink the container's Claude project key to the host's so both share the same chat history.
    // ${localWorkspaceFolder} and ${containerWorkspaceFolder} are substituted by the devcontainer
    // spec before the shell runs; Claude's project key format is the path with slashes → dashes.
    "link_claude_project": "HOST_KEY=$(echo \"${localWorkspaceFolder}\" | tr '/' '-') && CONTAINER_KEY=$(echo \"${containerWorkspaceFolder}\" | tr '/' '-') && mkdir -p ~/.claude/projects/\"$HOST_KEY\" && ln -sfn ~/.claude/projects/\"$HOST_KEY\" ~/.claude/projects/\"$CONTAINER_KEY\" || true",
    // Symlink the container's Copilot workspaceStorage hash directory to the host's.
    // The script computes the container hash from the known VS Code URI formula and locates
    // the host hash by scanning workspace.json files in the mounted host VS Code storage.
    "link_copilot_history": "python3 \"${containerWorkspaceFolder}/.devcontainer/.dev/link-copilot-storage.py\" \"${localWorkspaceFolder}\" \"${containerWorkspaceFolder}\" \"${localWorkspaceFolder}/.devcontainer/.dev/devcontainer.json\" || true"
  },
  "overrideFeatureInstallOrder": [
    "ghcr.io/quantized8/sysset/install-git",
    "../.src/install-git",

    "ghcr.io/quantized8/sysset/install-jq",
    "ghcr.io/quantized8/sysset/install-yq",
    "ghcr.io/quantized8/sysset/setup-user",
    "ghcr.io/quantized8/sysset/install-shell",
    "ghcr.io/quantized8/sysset/install-gh",
    "ghcr.io/quantized8/sysset/install-just",
    "ghcr.io/quantized8/sysset/install-shfmt",
    "ghcr.io/quantized8/sysset/install-shellcheck",

    "ghcr.io/quantized8/sysset/install-miniforge",

    "ghcr.io/quantized8/sysset/install-pixi",
    "ghcr.io/quantized8/sysset/install-node",
    "ghcr.io/quantized8/sysset/install-devcontainer-cli",
    "ghcr.io/devcontainers/features/docker-in-docker:2",
    "ghcr.io/quantized8/sysset/install-oras"
  ],
  "customizations": {
    "vscode": {
      "settings": {
        // ── File Watcher / Search Excludes ──────────────────────────────────────
        // Prevents virtiofs cross-VM inotify storms on large/generated directories
        "files.watcherExclude": {
          "**/.git/**": true,
          "**/__pycache__/**": true,
          "**/.pixi/**": true,
          "**/miniforge3/**": true,
          "**/*.egg-info/**": true
        },
        "search.exclude": {
          "**/.git": true,
          "**/__pycache__": true,
          "**/.pixi": true,
          "**/miniforge3": true
        },
        // Prevents Pylance from indexing conda/pixi envs (has its own watcher, ignores files.watcherExclude)
        "python.analysis.exclude": [
          "**/.pixi/**",
          "**/miniforge3/**"
        ],
        // ── Bash IDE (shellcheck) ────────────────────────────────────────────────
        // Default is 500 files analysed in parallel — causes 8+ concurrent shellcheck
        // processes each at 30%+ CPU on this workspace due to --external-sources chains.
        // Limit to 1 background file at a time; active file is still linted on save.
        "bashIde.backgroundAnalysisMaxFiles": 1,
        // Stop bash-ide following --source-path chains across the whole workspace,
        // which is what makes each shellcheck process so expensive here.
        "bashIde.enableSourceErrorDiagnostics": false,
        // ── YAML Schema ─────────────────────────────────────────────────────────
        "yaml.schemas": {
            "features/metadata.schema.json": ["features/*/metadata.yaml"]
        },
        "yaml.schemaStore.enable": false,
        "yaml.trace.server": "verbose",
        // ── JSON Schema ─────────────────────────────────────────────────────────
        "json.schemas": [
          {
            "fileMatch": [
              "**/devcontainer-feature.json"
            ],
            "url": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainerFeature.schema.json"
          }
        ]
      },
      "extensions": [
        "mads-hartmann.bash-ide-vscode",
        "EditorConfig.EditorConfig",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml",
        "ms-python.python",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "charliermarsh.ruff",
        "ms-azuretools.vscode-docker",
        "yzhang.markdown-all-in-one",
        "anthropic.claude-code",
        "tomoki1207.pdf"
      ]
    }
  }
}
