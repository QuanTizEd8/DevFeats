{
  "name": "DevFeats Development Environment",
  "containerUser": "devfeats-dev",
  "remoteUser": "devfeats-dev",
  "build": {
    // Currently, there is no way to define cache sources when using "image",
    // so we have to use "dockerfile" even though we don't need a custom one.
    "dockerfile": "Dockerfile",
    "options": [
      "--progress=plain"
    ],
    "cacheFrom": [
      "ghcr.io/quantized8/devfeats-devcontainer:cache-linux-amd64",
      "ghcr.io/quantized8/devfeats-devcontainer:cache-linux-arm64"
    ]
  },
  "features": {
    "ghcr.io/quantized8/devfeats/setup-user": {
      "username": "devfeats-dev"
    },
    "ghcr.io/quantized8/devfeats/install-gh": {},
    "ghcr.io/quantized8/devfeats/install-git": {},
    "ghcr.io/quantized8/devfeats/install-jq": {},
    "ghcr.io/quantized8/devfeats/install-just": {
      "version": "1.50.0"
    },
    "ghcr.io/quantized8/devfeats/install-shfmt": {
      "version": "3.13.1"
    },
    "ghcr.io/quantized8/devfeats/install-shellcheck": {
      "version": "0.11.0"
    },
    "ghcr.io/quantized8/devfeats/install-miniforge": {},
    "ghcr.io/quantized8/devfeats/install-shell": {},
    "ghcr.io/quantized8/devfeats/install-yq": {},
    "ghcr.io/quantized8/devfeats/install-devcontainer-cli": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  // "postCreateCommand": "lefthook install",
  "postStartCommand": {
    "initialize_bats_submodules": "git submodule update --init --recursive",
    "pixi_install": "pixi install"
  },
  "customizations": {
    "vscode": {
      "settings": {
        // ── YAML Schema ─────────────────────────────────────────────────────────
        "yaml.schemas": {
            "features/metadata.schema.json": ["features/*/metadata.yaml"]
        },
        "yaml.schemaStore.enable": false,
        "yaml.trace.server": "verbose",
        // ── JSON Schema ─────────────────────────────────────────────────────────
        "json.schemas": [
          {
            "fileMatch": [
              "**/devcontainer-feature.json"
            ],
            "url": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainerFeature.schema.json"
          }
        ]
      },
      "extensions": [
        "mads-hartmann.bash-ide-vscode",
        "EditorConfig.EditorConfig",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml",
        "ms-python.python"
      ]
    }
  }
}
