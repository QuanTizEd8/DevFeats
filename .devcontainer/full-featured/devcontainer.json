{
    "name": "SysSet Full Featured Dev Container",
    "image": "ubuntu:latest",
    "initializeCommand": "bash scripts/sync-src.sh",
    "containerUser": "sysuser",
    "features": {
      "../.src/install-os-pkg": {},
      "../.src/setup-user": {
        "username": "sysuser"
      },
      "../.src/setup-shim": {},
      "../.src/install-git": {},
      "../.src/install-shell": {},
      "../.src/install-homebrew": {},
      "../.src/install-gh": {},
      "../.src/install-podman": {},
      "../.src/install-node": {},
      "../.src/install-miniforge": {},
      "../.src/install-pixi": {},
      "../.src/install-fonts": {}
    },
    "overrideFeatureInstallOrder": [
      "../.src/setup-user",
      "../.src/setup-shim",
      "../.src/install-git",
      "../.src/install-shell",
      "../.src/install-homebrew",
      "../.src/install-gh",
      "../.src/install-podman",
      "../.src/install-node",
      "../.src/install-miniforge",
      "../.src/install-pixi",
      "../.src/install-fonts"
    ]
}
