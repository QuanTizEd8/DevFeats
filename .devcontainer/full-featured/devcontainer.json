{
    "name": "combined",
    "image": "ubuntu:latest",
    "initializeCommand": "bash scripts/sync-src.sh",
    "containerUser": "vscode",
    "features": {
      "../_src/install-os-pkg": {},
      "../_src/setup-user": {},
      "../_src/setup-shim": {},
      "../_src/install-git": {},
      "../_src/install-shell": {},
      "../src/install-homebrew": {},
      "../_src/install-gh": {},
      "../_src/install-podman": {},
      "../_src/install-node": {},
      "../_src/install-miniforge": {},
      "../_src/install-pixi": {},
      "../_src/install-fonts": {}
    },
    "overrideFeatureInstallOrder": [
      "../_src/setup-user",
      "../_src/setup-shim",
      "../_src/install-git",
      "../_src/install-shell",
      "../src/install-homebrew",
      "../_src/install-gh",
      "../_src/install-podman",
      "../_src/install-node",
      "../_src/install-miniforge",
      "../_src/install-pixi",
      "../_src/install-fonts"
    ]
}
