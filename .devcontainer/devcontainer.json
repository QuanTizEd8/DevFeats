{
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "settings": {
                "json.schemas": [
                    {
                        "fileMatch": [
                            "*/devcontainer-feature.json"
                        ],
                        "url": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainerFeature.schema.json"
                    }
                ]
            },
            "extensions": [
                "mads-hartmann.bash-ide-vscode",
                "timonwong.shellcheck",
                "foxundermoon.shell-format",
                "EditorConfig.EditorConfig",
                "redhat.vscode-yaml",
                // Syntax support for 'just': https://marketplace.visualstudio.com/items?itemName=nefrob.vscode-just-syntax
                "nefrob.vscode-just-syntax"
            ]
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {}
    },
    "remoteUser": "node",
    "initializeCommand": "bash scripts/sync-src.sh",
    "updateContentCommand": "npm install -g @devcontainers/cli lefthook",
    "postCreateCommand": "lefthook install"
}
