{
    "apt_default": {
        "remoteUser": "vscode",
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-podman": {
                "log_level": "trace"
            }
        }
    },
    "apt_root_user_config": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-podman": {
                "add_users": "root",
                "log_level": "trace"
            }
        }
    },
    "apt_remote_user": {
        "remoteUser": "vscode",
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-podman": {
                "add_remote_user": true,
                "add_container_user": false,
                "add_current_user": false,
                "log_level": "trace"
            }
        }
    },
    "apt_container_user": {
        "containerUser": "vscode",
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-podman": {
                "add_container_user": true,
                "add_remote_user": false,
                "add_current_user": false,
                "log_level": "trace"
            }
        }
    },
    "apt_explicit_user": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-podman": {
                "add_users": "devuser",
                "add_remote_user": false,
                "add_container_user": false,
                "add_current_user": false,
                "log_level": "trace"
            }
        }
    },
    "apt_multi_user": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-podman": {
                "add_users": "alice\nbob",
                "add_remote_user": false,
                "add_container_user": false,
                "add_current_user": false,
                "log_level": "trace"
            }
        }
    },
    "apt_no_users": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-podman": {
                "add_remote_user": false,
                "add_container_user": false,
                "add_current_user": false,
                "log_level": "trace"
            }
        }
    },
    "apt_nonexistent_user": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-podman": {
                "add_users": "ghost",
                "add_remote_user": false,
                "add_container_user": false,
                "add_current_user": false,
                "log_level": "trace"
            }
        }
    }
}
