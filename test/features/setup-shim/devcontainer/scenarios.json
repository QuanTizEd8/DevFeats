{
    "default": {
        "image": "ubuntu:latest",
        "features": {
            "setup-shim": {
                "log_level": "trace"
            }
        }
    },
    "code_only": {
        "image": "ubuntu:latest",
        "features": {
            "setup-shim": {
                "code": true,
                "devcontainer-info": false,
                "systemctl": false,
                "log_level": "trace"
            }
        }
    },
    "none_enabled": {
        "image": "ubuntu:latest",
        "features": {
            "setup-shim": {
                "code": false,
                "devcontainer-info": false,
                "systemctl": false,
                "log_level": "trace"
            }
        }
    }
}
