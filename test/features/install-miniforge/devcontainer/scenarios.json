{
    "download_and_install": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": {
                "log_level": "trace"
            }
        }
    },
    "custom_bin_dir": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": {
                "prefix": "/opt/myforge",
                "symlink": false,
                "log_level": "trace"
            }
        }
    },
    "specific_version": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": {
                "version": "24.7.1",
                "log_level": "trace"
            }
        }
    },
    "set_permission": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": {
                "write_group": "conda",
                "log_level": "trace"
            }
        }
    },
    "activate_bashrc": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": {
                "shell_activations": "bash",
                "log_level": "trace"
            }
        }
    },
    "activate_multi": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-miniforge": {
                "shell_activations": "bash\nzsh",
                "log_level": "trace"
            }
        }
    },
    "custom_active_env": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": {
                "shell_activations": "bash",
                "activate_env": "myenv",
                "log_level": "trace"
            }
        }
    },
    "log_file": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": {
                "log_file": "/tmp/miniforge.log",
                "log_level": "trace"
            }
        }
    },
    "keep_installer": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": {
                "keep_installer": true,
                "log_level": "trace"
            }
        }
    },
    "if_exists_reinstall": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-miniforge": {
                "if_exists": "reinstall",
                "log_level": "trace"
            }
        }
    },
    "if_exists_skip": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-miniforge": {
                "if_exists": "skip",
                "log_level": "trace"
            }
        }
    },
    "if_exists_fail": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": {
                "if_exists": "fail",
                "log_level": "trace"
            }
        }
    },
    "if_exists_update": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": {
                "if_exists": "update",
                "log_level": "trace"
            }
        }
    },
    "debian": {
        "image": "debian:latest",
        "features": {
            "install-miniforge": {
                "log_level": "trace"
            }
        }
    },
    "multi_user_permissions": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-miniforge": {
                "write_group": "conda",
                "add_users": "testuser1\ntestuser2",
                "log_level": "trace"
            }
        }
    },
    "export_path_default": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": {
                "log_level": "trace"
            }
        }
    },
    "export_path_custom_dir": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": {
                "prefix": "/opt/myforge",
                "symlink": false,
                "log_level": "trace"
            }
        }
    },
    "export_path_symlink": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": {
                "prefix": "/opt/myforge",
                "symlink": true,
                "log_level": "trace"
            }
        }
    },
    "export_path_disabled": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": {
                "export_path": "",
                "log_level": "trace"
            }
        }
    },
    "export_path_custom_list": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": {
                "export_path": "/tmp/test_bashrc",
                "log_level": "trace"
            }
        }
    },
    "export_path_idempotency": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-miniforge": {
                "prefix": "/opt/myforge",
                "symlink": false,
                "log_level": "trace"
            }
        }
    },
    "latest_version": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": {
                "log_level": "trace"
            }
        }
    },
    "version_match_idempotency": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-miniforge": {
                "version": "24.7.1",
                "if_exists": "reinstall",
                "log_level": "trace"
            }
        }
    },
    "preserve_envs_true": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-miniforge": {
                "if_exists": "reinstall",
                "preserve_envs": true,
                "log_level": "trace"
            }
        }
    },
    "preserve_envs_false": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-miniforge": {
                "if_exists": "reinstall",
                "preserve_envs": false,
                "log_level": "trace"
            }
        }
    },
    "preserve_config_true": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-miniforge": {
                "if_exists": "reinstall",
                "preserve_config": true,
                "log_level": "trace"
            }
        }
    },
    "preserve_config_false": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-miniforge": {
                "if_exists": "reinstall",
                "preserve_config": false,
                "log_level": "trace"
            }
        }
    },
    "if_exists_update_preinstall": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-miniforge": {
                "if_exists": "update",
                "log_level": "trace"
            }
        }
    },
    "export_path_symlink_nonroot": {
        "remoteUser": "vscode",
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-miniforge": {
                "prefix": "/opt/myforge",
                "symlink": true,
                "log_level": "trace"
            }
        }
    },
    "symlink_user_home_prefix": {
        "image": "ubuntu:latest",
        "features": {
            "install-miniforge": {
                "prefix": "/root/myforge",
                "symlink": true,
                "log_level": "trace"
            }
        }
    }
}
