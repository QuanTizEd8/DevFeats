{
    "inline_env": {
        "image": "condaforge/miniforge3",
        "features": {
            "install-conda-env": {
                "env_name": "myenv",
                "packages": "numpy pandas",
                "log_level": "trace"
            }
        }
    },
    "python_version": {
        "image": "condaforge/miniforge3",
        "features": {
            "install-conda-env": {
                "env_name": "py311",
                "python_version": "3.11",
                "log_level": "trace"
            }
        }
    },
    "env_files": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-conda-env": {
                "env_files": "/tmp/test-envs/simple.yml",
                "log_level": "trace"
            }
        }
    },
    "env_dirs": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-conda-env": {
                "env_dirs": "/tmp/test-envs",
                "log_level": "trace"
            }
        }
    },
    "multi_env_files": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-conda-env": {
                "env_files": "/tmp/test-envs/envA.yml\n/tmp/test-envs/envB.yml",
                "log_level": "trace"
            }
        }
    },
    "update_existing": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-conda-env": {
                "env_files": "/tmp/test-envs/simple.yml",
                "log_level": "trace"
            }
        }
    },
    "channels": {
        "image": "condaforge/miniforge3",
        "features": {
            "install-conda-env": {
                "env_name": "chanenv",
                "packages": "numpy",
                "channels": "conda-forge\ndefaults",
                "log_level": "trace"
            }
        }
    },
    "strict_channel_priority": {
        "image": "condaforge/miniforge3",
        "features": {
            "install-conda-env": {
                "env_name": "strictenv",
                "packages": "numpy",
                "channels": "conda-forge",
                "strict_channel_priority": true,
                "log_level": "trace"
            }
        }
    },
    "solver_conda": {
        "image": "condaforge/miniforge3",
        "features": {
            "install-conda-env": {
                "env_name": "solverenv",
                "packages": "numpy",
                "solver": "conda",
                "log_level": "trace"
            }
        }
    },
    "pip_requirements": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-conda-env": {
                "env_name": "pipenv",
                "packages": "pip",
                "pip_requirements_files": "/tmp/requirements.txt",
                "log_level": "trace"
            }
        }
    },
    "pip_env_override": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-conda-env": {
                "env_name": "pipenv",
                "packages": "pip",
                "pip_requirements_files": "/tmp/requirements.txt",
                "pip_env": "pipenv",
                "log_level": "trace"
            }
        }
    },
    "post_env_script": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-conda-env": {
                "env_name": "scriptenv",
                "packages": "numpy",
                "post_env_script": "/tmp/post-env.sh",
                "log_level": "trace"
            }
        }
    },
    "log_file": {
        "image": "condaforge/miniforge3",
        "features": {
            "install-conda-env": {
                "env_name": "logenv",
                "packages": "numpy",
                "log_file": "/tmp/conda-env.log",
                "log_level": "trace"
            }
        }
    },
    "keep_cache": {
        "image": "condaforge/miniforge3",
        "features": {
            "install-conda-env": {
                "env_name": "cleanenv",
                "packages": "numpy",
                "keep_cache": true,
                "log_level": "trace"
            }
        }
    }
}
