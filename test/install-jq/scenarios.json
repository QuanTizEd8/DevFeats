{
    "default_install": {
        "image": "ubuntu:latest",
        "features": {
            "install-jq": {
                "log_level": "trace"
            }
        }
    },
    "specific_version": {
        "image": "ubuntu:latest",
        "features": {
            "install-jq": {
                "version": "1.8.1",
                "method": "release",
                "log_level": "trace"
            }
        }
    },
    "release_custom_prefix": {
        "image": "ubuntu:latest",
        "features": {
            "install-jq": {
                "method": "release",
                "prefix": "/opt/jq-bin",
                "symlink": true,
                "if_exists": "reinstall",
                "log_level": "trace"
            }
        }
    },
    "custom_prefix_no_symlink": {
        "image": "ubuntu:latest",
        "features": {
            "install-jq": {
                "method": "release",
                "prefix": "/opt/jq-bin",
                "symlink": false,
                "log_level": "trace"
            }
        }
    },
    "repos_install_debian": {
        "image": "debian:latest",
        "features": {
            "install-jq": {
                "method": "repos",
                "log_level": "trace"
            }
        }
    },
    "repos_install_alpine": {
        "image": "alpine:latest",
        "features": {
            "install-jq": {
                "method": "repos",
                "log_level": "trace"
            }
        }
    },
    "repos_install_fedora": {
        "image": "fedora:latest",
        "features": {
            "install-jq": {
                "method": "repos",
                "log_level": "trace"
            }
        }
    },
    "legacy_version": {
        "image": "ubuntu:latest",
        "features": {
            "install-jq": {
                "version": "1.6",
                "method": "release",
                "log_level": "trace"
            }
        }
    },
    "version_match_idempotency": {
        "build": {
            "dockerfile": "version_match_idempotency/Dockerfile",
            "args": {}
        },
        "features": {
            "install-jq": {
                "version": "1.8.1",
                "if_exists": "fail",
                "log_level": "trace"
            }
        }
    },
    "reinstall": {
        "build": {
            "dockerfile": "reinstall/Dockerfile",
            "args": {}
        },
        "features": {
            "install-jq": {
                "version": "1.7.1",
                "method": "release",
                "if_exists": "reinstall",
                "log_level": "trace"
            }
        }
    }
}
