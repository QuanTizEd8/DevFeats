{
    "default_install": {
        "image": "ubuntu:latest",
        "features": {
            "install-yq": {
                "log_level": "trace"
            }
        }
    },
    "specific_version": {
        "image": "ubuntu:latest",
        "features": {
            "install-yq": {
                "version": "4.44.2",
                "method": "release",
                "log_level": "trace"
            }
        }
    },
    "release_custom_prefix": {
        "image": "ubuntu:latest",
        "features": {
            "install-yq": {
                "method": "release",
                "prefix": "/opt/yq-bin",
                "symlink": true,
                "if_exists": "reinstall",
                "log_level": "trace"
            }
        }
    },
    "custom_prefix_no_symlink": {
        "image": "ubuntu:latest",
        "features": {
            "install-yq": {
                "method": "release",
                "prefix": "/opt/yq-bin",
                "symlink": false,
                "log_level": "trace"
            }
        }
    },
    "repos_install": {
        "image": "debian:latest",
        "features": {
            "install-yq": {
                "method": "auto",
                "if_exists": "reinstall",
                "log_level": "trace"
            }
        }
    },
    "version_match_idempotency": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-yq": {
                "version": "4.44.2",
                "if_exists": "fail",
                "log_level": "trace"
            }
        }
    },
    "shell_completion_bash": {
        "image": "ubuntu:latest",
        "features": {
            "install-yq": {
                "shell_completions": "bash",
                "log_level": "trace"
            }
        }
    },
    "shell_completion_zsh": {
        "image": "ubuntu:latest",
        "features": {
            "install-yq": {
                "shell_completions": "zsh",
                "log_level": "trace"
            }
        }
    }
}
