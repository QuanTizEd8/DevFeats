{
    "default": {
        "image": "ubuntu:latest",
        "features": {
            "setup-user": {
                "log_level": "trace"
            }
        }
    },
    "no_sudo": {
        "image": "ubuntu:latest",
        "features": {
            "setup-user": {
                "sudo_access": false,
                "log_level": "trace"
            }
        }
    },
    "custom_user": {
        "image": "ubuntu:latest",
        "features": {
            "setup-user": {
                "username": "devuser",
                "user_id": "2000",
                "group_id": "2000",
                "group_name": "devgroup",
                "log_level": "trace"
            }
        }
    },
    "custom_home": {
        "image": "ubuntu:latest",
        "features": {
            "setup-user": {
                "home_dir": "/workspaces/myapp",
                "log_level": "trace"
            }
        }
    },
    "custom_shell": {
        "image": "ubuntu:latest",
        "features": {
            "setup-user": {
                "user_shell": "/bin/sh",
                "log_level": "trace"
            }
        }
    },
    "extra_groups": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "setup-user": {
                "extra_groups": "builders\ntesters",
                "log_level": "trace"
            }
        }
    },
    "replace_existing": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "setup-user": {
                "log_level": "trace"
            }
        }
    },
    "already_configured": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "setup-user": {
                "replace_existing": false,
                "sudo_access": false,
                "log_level": "trace"
            }
        }
    },
    "alpine": {
        "image": "alpine:latest",
        "features": {
            "setup-user": {
                "log_level": "trace"
            }
        }
    },
    "log_file": {
        "image": "ubuntu:latest",
        "features": {
            "setup-user": {
                "log_file": "/tmp/setup-user.log",
                "log_level": "trace"
            }
        }
    }
}
