{
    "default_install": {
        "image": "ubuntu:latest",
        "features": {
            "install-gh": {
                "log_level": "trace"
            }
        }
    },
    "specific_version_binary": {
        "image": "ubuntu:latest",
        "features": {
            "install-gh": {
                "version": "2.67.0",
                "method": "binary",
                "log_level": "trace"
            }
        }
    },
    "repos_debian": {
        "image": "debian:12",
        "features": {
            "install-gh": {
                "log_level": "trace"
            }
        }
    },
    "repos_alpine": {
        "image": "alpine:3.20",
        "features": {
            "install-gh": {
                "log_level": "trace"
            }
        }
    },
    "repos_fedora": {
        "image": "fedora:41",
        "features": {
            "install-gh": {
                "log_level": "trace"
            }
        }
    },
    "repos_opensuse": {
        "image": "opensuse/leap:15.6",
        "features": {
            "install-gh": {
                "log_level": "trace"
            }
        }
    },
    "binary_custom_path": {
        "image": "ubuntu:latest",
        "features": {
            "install-gh": {
                "method": "binary",
                "prefix": "/opt/gh",
                "symlink": true,
                "log_level": "trace"
            }
        }
    },
    "binary_no_symlink": {
        "image": "ubuntu:latest",
        "features": {
            "install-gh": {
                "method": "binary",
                "prefix": "/opt/gh",
                "symlink": false,
                "log_level": "trace"
            }
        }
    },
    "binary_no_completions": {
        "image": "ubuntu:latest",
        "features": {
            "install-gh": {
                "method": "binary",
                "shell_completions": "",
                "log_level": "trace"
            }
        }
    },
    "repos_no_completions": {
        "image": "ubuntu:latest",
        "features": {
            "install-gh": {
                "shell_completions": "",
                "log_level": "trace"
            }
        }
    },
    "git_protocol_https": {
        "remoteUser": "vscode",
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-gh": {
                "add_remote_user": true,
                "add_current_user": false,
                "add_container_user": false,
                "git_protocol": "https",
                "log_level": "trace"
            }
        }
    },
    "setup_git": {
        "remoteUser": "vscode",
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-gh": {
                "add_remote_user": true,
                "add_current_user": false,
                "add_container_user": false,
                "setup_git": true,
                "log_level": "trace"
            }
        }
    },
    "sign_commits_ssh": {
        "remoteUser": "vscode",
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-gh": {
                "add_remote_user": true,
                "add_current_user": false,
                "add_container_user": false,
                "sign_commits": "ssh",
                "log_level": "trace"
            }
        }
    },
    "sign_commits_gpg": {
        "remoteUser": "vscode",
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-gh": {
                "add_remote_user": true,
                "add_current_user": false,
                "add_container_user": false,
                "sign_commits": "gpg",
                "log_level": "trace"
            }
        }
    },
    "if_exists_skip": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-gh": {
                "if_exists": "skip",
                "log_level": "trace"
            }
        }
    },
    "if_exists_skip_no_mutation": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-gh": {
                "if_exists": "skip",
                "log_level": "trace"
            }
        }
    },
    "version_match_idempotency": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-gh": {
                "method": "binary",
                "version": "2.67.0",
                "if_exists": "fail",
                "log_level": "trace"
            }
        }
    },
    "keep_installer": {
        "image": "ubuntu:latest",
        "features": {
            "install-gh": {
                "method": "binary",
                "keep_installer": true,
                "installer_dir": "/tmp/gh-trace",
                "log_level": "trace"
            }
        }
    },
    "log_file": {
        "image": "ubuntu:latest",
        "features": {
            "install-gh": {
                "log_file": "/tmp/gh-install.log",
                "log_level": "trace"
            }
        }
    },
    "binary_custom_path_nonroot": {
        "remoteUser": "vscode",
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-gh": {
                "method": "binary",
                "prefix": "/opt/gh",
                "symlink": true,
                "log_level": "trace"
            }
        }
    },
    "ghes_hostname": {
        "remoteUser": "vscode",
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-gh": {
                "add_remote_user": true,
                "add_current_user": false,
                "add_container_user": false,
                "setup_git": true,
                "git_hostname": "git.corp.example.com",
                "log_level": "trace"
            }
        }
    },
    "add_users": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-gh": {
                "add_users": "testuser",
                "add_current_user": false,
                "add_remote_user": false,
                "add_container_user": false,
                "setup_git": true,
                "log_level": "trace"
            }
        }
    },
    "extensions": {
        "remoteUser": "vscode",
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-gh": {
                "add_remote_user": true,
                "add_current_user": false,
                "add_container_user": false,
                "extensions": "github/gh-copilot",
                "log_file": "/tmp/gh-ext-install.log",
                "log_level": "trace"
            }
        }
    },
    "binary_symlink_user_home_prefix": {
        "image": "ubuntu:latest",
        "features": {
            "install-gh": {
                "method": "binary",
                "prefix": "/root/gh",
                "symlink": true,
                "log_level": "trace"
            }
        }
    }
}
