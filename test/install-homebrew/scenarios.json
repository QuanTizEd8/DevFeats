{
    "apt_default": {
        "image": "ubuntu:latest",
        "features": {
            "install-homebrew": {
                "log_level": "trace"
            }
        }
    },
    "debian": {
        "image": "debian:latest",
        "features": {
            "install-homebrew": {
                "log_level": "trace"
            }
        }
    },
    "export_path_disabled": {
        "image": "ubuntu:latest",
        "features": {
            "install-homebrew": {
                "export_path": "",
                "log_level": "trace"
            }
        }
    },
    "export_path_custom_file": {
        "image": "ubuntu:latest",
        "features": {
            "install-homebrew": {
                "export_path": "/tmp/custom-brew.sh",
                "log_level": "trace"
            }
        }
    },
    "export_path_idempotent": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-homebrew": {
                "log_level": "trace"
            }
        }
    },
    "if_exists_skip": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-homebrew": {
                "log_level": "trace"
            }
        }
    },
    "arch": {
        "image": "archlinux:latest",
        "features": {
            "install-homebrew": {
                "log_level": "trace"
            }
        }
    },
    "fedora": {
        "image": "fedora:latest",
        "features": {
            "install-homebrew": {
                "log_level": "trace"
            }
        }
    },
    "opensuse": {
        "image": "opensuse/leap:latest",
        "features": {
            "install-homebrew": {
                "log_level": "trace"
            }
        }
    },
    "if_exists_reinstall": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-homebrew": {
                "if_exists": "reinstall",
                "log_level": "trace"
            }
        }
    },
    "update_false": {
        "image": "ubuntu:latest",
        "features": {
            "install-homebrew": {
                "update": false,
                "log_level": "trace"
            }
        }
    },
    "log_file": {
        "image": "ubuntu:latest",
        "features": {
            "install-homebrew": {
                "log_file": "/tmp/brew.log",
                "log_level": "trace"
            }
        }
    },
    "shellenv_remote_user": {
        "remoteUser": "vscode",
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-homebrew": {
                "add_remote_user": true,
                "log_level": "trace"
            }
        }
    }
}
