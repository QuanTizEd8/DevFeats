{
    "package_default": {
        "image": "ubuntu:24.04",
        "features": {
            "install-git": {
                "log_level": "trace"
            }
        }
    },
    "package_debian": {
        "image": "debian:12",
        "features": {
            "install-git": {
                "version": "stable",
                "log_level": "trace"
            }
        }
    },
    "package_stable": {
        "image": "ubuntu:24.04",
        "features": {
            "install-git": {
                "version": "stable",
                "prefix": "/opt/git",
                "export_path": "/tmp/install-git-path.sh",
                "symlink": false,
                "shell_completions": "",
                "keep_installer": true,
                "log_level": "trace"
            }
        }
    },
    "package_alpine": {
        "image": "alpine:3.20",
        "features": {
            "install-git": {
                "version": "stable",
                "log_level": "trace"
            }
        }
    },
    "package_fedora": {
        "image": "fedora:41",
        "features": {
            "install-git": {
                "version": "stable",
                "log_level": "trace"
            }
        }
    },
    "gitconfig_system": {
        "image": "ubuntu:24.04",
        "features": {
            "install-git": {
                "default_branch": "trunk",
                "safe_directory": "*\n/workspaces/sysset\n/tmp/repo",
                "system_gitconfig": "[push]\n  default = simple\n[fetch]\n  prune = true",
                "log_level": "trace"
            }
        }
    },
    "gitconfig_user": {
        "remoteUser": "vscode",
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-git": {
                "add_remote_user": true,
                "user_name": "Dev User",
                "user_email": "dev@example.com",
                "user_gitconfig": "[pull]\n  rebase = false",
                "log_level": "trace"
            }
        }
    },
    "log_file": {
        "image": "ubuntu:24.04",
        "features": {
            "install-git": {
                "log_file": "/tmp/git.log",
                "log_level": "trace"
            }
        }
    },
    "source_stable": {
        "image": "ubuntu:24.04",
        "features": {
            "install-git": {
                "method": "source",
                "version": "stable",
                "log_level": "trace"
            }
        }
    },
    "source_pinned": {
        "image": "ubuntu:24.04",
        "features": {
            "install-git": {
                "method": "source",
                "version": "2.47.2",
                "log_level": "trace"
            }
        }
    },
    "source_keep_installer": {
        "image": "ubuntu:24.04",
        "features": {
            "install-git": {
                "method": "source",
                "version": "stable",
                "keep_installer": true,
                "log_level": "trace"
            }
        }
    },
    "source_custom_prefix": {
        "image": "ubuntu:24.04",
        "features": {
            "install-git": {
                "method": "source",
                "version": "stable",
                "prefix": "/opt/git",
                "log_level": "trace"
            }
        }
    },
    "source_export_path_disabled": {
        "image": "ubuntu:24.04",
        "features": {
            "install-git": {
                "method": "source",
                "version": "stable",
                "prefix": "/opt/git",
                "export_path": "",
                "symlink": false,
                "log_level": "trace"
            }
        }
    },
    "source_no_flags_perl": {
        "image": "ubuntu:24.04",
        "features": {
            "install-git": {
                "method": "source",
                "version": "stable",
                "no_flags": "perl",
                "log_level": "trace"
            }
        }
    },
    "if_exists_skip": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-git": {
                "if_exists": "skip",
                "log_level": "trace"
            }
        }
    },
    "if_exists_reinstall_source": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-git": {
                "method": "source",
                "version": "stable",
                "prefix": "/opt/git",
                "if_exists": "reinstall",
                "default_branch": "trunk",
                "log_level": "trace"
            }
        }
    },
    "if_exists_update_package": {
        "build": {
            "dockerfile": "Dockerfile",
            "args": {
                "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
            }
        },
        "features": {
            "install-git": {
                "if_exists": "update",
                "version": "stable",
                "default_branch": "trunk",
                "log_level": "trace"
            }
        }
    },
    "if_exists_fail": {
        "image": "ubuntu:24.04",
        "features": {
            "install-git": {
                "if_exists": "fail",
                "log_level": "trace"
            }
        }
    }
}
