{
    // ── Shell script tooling ──────────────────────────────────────────────────
    "[shellscript]": {
        "editor.defaultFormatter": "foxundermoon.shell-format",
        "editor.formatOnSave": true
    },
    "shellformat.effectLanguages": [
        "shellscript"
    ],
    "shellcheck.enable": true,
    "shellcheck.run": "onSave",
    "files.associations": {
        "*.bats": "shellscript"
    },
    // ── JSON Schema ─────────────────────────────────────────────────────────
    "json.schemas": [
        {
            "fileMatch": [
                "features/*/metadata.yaml"
            ],
            "url": "https://raw.githubusercontent.com/QuanTizEd8/SysSet/main/features/metadata.schema.json"
        }
    ],
    "json.trace.server": "verbose",

    // ── Copilot ───────────────────────────────────────────────────────────────
    "chat.checkpoints.showFileChanges": true,
    "chat.agent.thinking.collapsedTools": "withThinking",
    "chat.restoreLastPanelSession": true,
    "chat.viewProgressBadge.enabled": true,
    "chat.mcp.discovery.enabled": {
        "claude-desktop": true,
        "cursor-workspace": true,
        "cursor-global": true,
        "windsurf": true
    },
    "chat.mcp.gallery.enabled": true,
    "makefile.configureOnOpen": false
}
