{
    // ── Python tooling ───────────────────────────────────────────────────────
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true
    },
    // ── Shell script tooling ──────────────────────────────────────────────────
    "[shellscript]": {
        "editor.defaultFormatter": "mads-hartmann.bash-ide-vscode",
        "editor.formatOnSave": true
    },
    "shellformat.effectLanguages": [
        "shellscript"
    ],
    "shellcheck.enable": true,
    "shellcheck.run": "onSave",
    "files.associations": {
        "*.bats": "shellscript"
    },
    // ── Copilot ───────────────────────────────────────────────────────────────
    "chat.checkpoints.showFileChanges": true,
    "chat.agent.thinking.collapsedTools": "withThinking",
    "chat.restoreLastPanelSession": true,
    "chat.viewProgressBadge.enabled": true,
    "chat.mcp.discovery.enabled": {
        "claude-desktop": true,
        "cursor-workspace": true,
        "cursor-global": true,
        "windsurf": true
    },
    "chat.mcp.gallery.enabled": true,
    "makefile.configureOnOpen": false,
    "python-envs.defaultEnvManager": "renan-r-santos.pixi-code:pixi",
    "python-envs.defaultPackageManager": "renan-r-santos.pixi-code:pixi",
    "python.defaultInterpreterPath": "${workspaceFolder}/.pixi/envs/default/bin/python",
    "python.analysis.exclude": [
      "**/node_modules",
      "**/__pycache__",
      "**/.*",
      ".claude/**",
      ".codex/**",
      ".copilot/**",
      ".cursor/**",
      ".windsurf/**",
    ],
    // ── YAML schemas ─────────────────────────────────────────────────────────
    "yaml.schemas": {
        "./features/metadata.schema.json": "features/*/metadata.yaml"
    },
    // ── Bash IDE (shellcheck) ────────────────────────────────────────────────
    // Default is 500 files analysed in parallel — causes 8+ concurrent shellcheck
    // processes each at 30%+ CPU on this workspace due to --external-sources chains.
    // Limit to 1 background file at a time; active file is still linted on save.
    "bashIde.backgroundAnalysisMaxFiles": 1,
    // Stop bash-ide following --source-path chains across the whole workspace,
    // which is what makes each shellcheck process so expensive here.
    "bashIde.enableSourceErrorDiagnostics": false,
}
