# -- discovery: @@STEM@@ (symlinks not available) --
local _df_call_exports=false
case "${@@DISCOVERY_VAR@@:-auto}" in
  none | symlink) ;;
  shell | all) _df_call_exports=true ;;
  auto)
    case ":${@@RUNTIME_PATH_VAR@@:-${PATH:-}}:" in
      *":${@@PREFIX_VAR@@}/@@BIN_DIR@@:"*) ;;
      *) _df_call_exports=true ;;
    esac
    ;;
esac
if "${_df_call_exports}"; then @@FUNC_EXPORTS@@; fi
