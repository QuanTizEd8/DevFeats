# shellcheck disable=SC2329,SC2317
@@FUNC_NAME@@() {
  logging__fn_entry "@@FUNC_NAME@@"
@@APPLIES_WHEN_GUARD@@  local _df_export_opt
  if [ "${#@@EXPORT_VAR@@[@]}" -eq 0 ]; then
    _df_export_opt="auto"
  else
    _df_export_opt="$(printf '%s\n' "${@@EXPORT_VAR@@[@]}")"
  fi
  local _df_path_dir="${@@PREFIX_VAR@@}/@@BIN_DIR@@"
  local _df_export_content
  # shellcheck disable=SC2162
  IFS= read -r -d '' _df_export_content << 'EOBLOCK' || true
__df_prepend_path() {
  local _d="$1" _p="${PATH:-}" _r="" _e
  while [ -n "$_p" ]; do
    _e="${_p%%:*}"; [ "$_p" = "${_p#*:}" ] && _p="" || _p="${_p#*:}"
    [ "$_e" = "$_d" ] || _r="${_r:+${_r}:}${_e}"
  done
  export PATH="${_d}${_r:+:${_r}}"
}
EOBLOCK
  _df_export_content="${_df_export_content}__df_prepend_path \"${_df_path_dir}\"
unset -f __df_prepend_path"
  shell__write_env_block \
    --opt "${_df_export_opt}" \
    --profile-d "${_EXPORT_PROFILE_D}" \
    --marker "@@MARKER@@" \
    --content "${_df_export_content}"
  logging__fn_exit "@@FUNC_NAME@@"
  return
}
