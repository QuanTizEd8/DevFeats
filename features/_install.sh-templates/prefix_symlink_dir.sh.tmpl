# shellcheck disable=SC2329,SC2317
@@FUNC_NAME@@() {
  logging__fn_entry "@@FUNC_NAME@@"
@@APPLIES_WHEN_GUARD@@  if [ "${@@SYMLINK_VAR@@}" != "true" ]; then
    logging__info "@@SYMLINK_OPT@@=false; skipping symlink creation."
    logging__fn_exit "@@FUNC_NAME@@"
    return 0
  fi
  shell__create_symlink \
    --src "${@@PREFIX_VAR@@}" \
    --system-target "@@DEFAULT_ROOT@@" \
    --user-target "@@DEFAULT_NONROOT@@"
  logging__fn_exit "@@FUNC_NAME@@"
  return
}
